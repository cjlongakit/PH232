<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for dark mode -->
    <style name="Base.Theme.PH232" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/purple_light</item>
        <item name="colorPrimaryDark">@color/purple_dark</item>
        <item name="colorAccent">@color/purple_light</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:windowBackground">@color/dark_background</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>

        <!-- Material Components -->
        <item name="materialCardViewStyle">@style/CustomCardStyle</item>
        <item name="materialButtonStyle">@style/CustomButtonStyle</item>
        <item name="textInputStyle">@style/CustomInputStyle</item>
    </style>

    <style name="CustomCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/dark_surface</item>
    </style>

    <style name="CustomButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

    <style name="CustomInputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxBackgroundColor">@color/dark_surface_elevated</item>
        <item name="boxStrokeColor">@color/purple_light</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/purple_light</item>
        <item name="endIconTint">@color/gray_400</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="CustomOutlinedButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/gray_300</item>
    </style>

    <style name="Theme.PH232" parent="Base.Theme.PH232" />

    <!-- Splash Screen Theme - purple background to avoid white flash -->
    <style name="Theme.PH232.Splash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/purple_dark</item>
        <item name="android:statusBarColor">@color/purple_dark</item>
        <item name="android:navigationBarColor">@color/purple_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="LoginCardShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">30dp</item>
        <item name="cornerSizeTopRight">30dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ToggleButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>
