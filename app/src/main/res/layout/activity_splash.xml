<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Purple background image -->
    <ImageView
        android:id="@+id/ivSplashBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ph323_purple_bg"
        android:contentDescription="Background" />

    <!-- Centered content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo with white background -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvSplashLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:elevation="8dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/ivSplashLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ph323_white_bg"
                android:contentDescription="PH323 Logo" />

        </androidx.cardview.widget.CardView>

        <!-- App name -->
        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PH 323"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Subtitle / tagline -->
        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attendance Management System"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- Bottom loading indicator -->
    <LinearLayout
        android:id="@+id/llSplashLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="60dp"
        android:orientation="vertical"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/pbSplash"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="#FFFFFF" />

        <TextView
            android:id="@+id/tvSplashLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</FrameLayout>

